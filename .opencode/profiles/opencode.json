{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/big-pickle",
  "small_model": "opencode/big-pickle",
  "provider": {
    "opencode": {
      "options": {
        "timeout": 120000,
        "headerTimeout": 30000,
        "chunkTimeout": 60000,
        "setCacheKey": true
      }
    }
  },
  "agent": {
    "architect": {
      "model": "opencode/big-pickle",
      "temperature": 0.5,
      "steps": 50
    },
    "developer": {
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "steps": 100
    },
    "tester": {
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "steps": 100
    },
    "security-auditor": {
      "model": "opencode/big-pickle",
      "temperature": 0.3,
      "steps": 50
    }
  }
}
